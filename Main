package Interfazes;

import java.util.Scanner;
import java.util.ArrayList;
import java.util.List;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        List<IAnimal> animales = new ArrayList<>();
        int opc;

        do {
            menu();
            System.out.print("Ingrese la opción: ");
            try {
                opc = Integer.parseInt(sc.nextLine());
            } catch (NumberFormatException e) {
                System.out.println("Por favor, ingrese un número válido.");
                opc = 0;
                continue;
            }

            switch (opc) {
                case 1:
                    System.out.print("Ingrese el nombre del perro: ");
                    String nombrePerro = sc.nextLine();
                    animales.add(new Perro(nombrePerro));
                    break;

                case 2:
                    System.out.print("Ingrese el nombre del gato: ");
                    String nombreGato = sc.nextLine();
                    animales.add(new Gato(nombreGato));
                    break;

                case 3:
                    System.out.println("\n--- LISTA DE ANIMALES ---");
                    if (animales.isEmpty()) {
                        System.out.println("No hay animales en la lista.");
                    } else {
                        for (IAnimal ia : animales) {
                            if (ia instanceof Animal) {
                                Animal a = (Animal) ia;
                                System.out.println(a.getNombre() + " es un " + a.tipoAnimal() + " y dice: " + ia.comunicarse());
                            } else {
                                System.out.println("Dice: " + ia.comunicarse());
                            }
                        }
                    }
                    break;

                case 4:
                    System.out.println("\n--- PERROS ---");
                    boolean hayPerros = false;
                    for (IAnimal ia : animales) {
                        if (ia instanceof Animal) {
                            Animal a = (Animal) ia;
                            if (a.tipoAnimal().equalsIgnoreCase("perro")) {
                                System.out.println("- " + a.getNombre() + " (" + ia.comunicarse() + ")");
                                hayPerros = true;
                            }
                        }
                    }
                    if (!hayPerros) System.out.println("No hay perros en la lista.");
                    break;

                case 5:
                    System.out.println("\n--- GATOS ---");
                    boolean hayGatos = false;
                    for (IAnimal ia : animales) {
                        if (ia instanceof Animal) {
                            Animal a = (Animal) ia;
                            if (a.tipoAnimal().equalsIgnoreCase("gato")) {
                                System.out.println("- " + a.getNombre() + " (" + ia.comunicarse() + ")");
                                hayGatos = true;
                            }
                        }
                    }
                    if (!hayGatos) System.out.println("No hay gatos en la lista.");
                    break;

                case 6:
                    System.out.println("Saliendo del programa... ¡Adiós!");
                    break;

                default:
                    System.out.println("Opción no válida. Intente de nuevo.");
                    break;
            }
            System.out.println();

        } while (opc != 6);

        sc.close();
    }

    public static void menu() {
        System.out.println("MENU");
        System.out.println("1. Ingrese perro");
        System.out.println("2. Ingrese gato");
        System.out.println("3. Mostrar lista completa");
        System.out.println("4. Mostrar perros");
        System.out.println("5. Mostrar gatos");
        System.out.println("6. Salir");
    }
}
